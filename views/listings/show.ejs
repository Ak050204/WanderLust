<% layout('layouts/boilerplate') %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3>Listing Details : </h3>
    </div>
<div class="card col-6 offset-3 show-card">
  <img src="<%= listing.image.url %>" class="card-img-top show-img" alts="listinga image">
  <div class="card-body">
    <p class="card-text">
      <b><%= listing.title %></b>
      <br>
      <%= listing.description %>  
      <br>
      <b>Price:</b> &#8377; <%= listing.price.toLocaleString("en-IN") %>
      <br>
       <b>Country:</b> <%= listing.country %>
      <br>
      <b>Location:</b> <%= listing.location %>
      <br>
    </p>
  </div>
</div>
<div class="btns">
  <a href="/Listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

<form action="/Listings/<%= listing._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn btn-dark offset-5">Delete</button>
    <br>
  </form>
</div>
</body>

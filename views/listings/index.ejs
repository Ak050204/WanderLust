<% layout('layouts/boilerplate') %>
<body>
  <h3>All Listings</h3>
  <!-- <form method="get" action="/listings/new">
  </form> -->
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 g-4">
<% for(let listing of allListings) { %>
  <a href="/listings/<%= listing.id %>" class="listings-link">
  <div class="card col">
  <img 
  src="<%= listing.image.url %>" class="card-img-top" alt="Listings Image" style="height: 20rem">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
      <b><%= listing.title %></b>
      <br>
      <%= listing.price.toLocaleString("en-IN") %> /night
    </p>
  </div>
</div>
</a>
<% } %>
</div>
</body>
